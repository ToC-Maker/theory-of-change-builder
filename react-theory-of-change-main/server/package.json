{
  "name": "toc-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend server for Theory of Change React app",
  "main": "server.ts",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build": "tsc server.ts --outDir dist --module esnext --target es2020 --moduleResolution bundler --allowSyntheticDefaultImports",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.3"
  }
}