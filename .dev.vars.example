# Copy to .dev.vars (gitignored) and fill in real values for local dev.
# These are also the variables needed as Cloudflare Workers secrets/vars in production.

# Secrets (set via `wrangler secret put` or dashboard → Variables and Secrets)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
ANTHROPIC_API_KEY="sk-ant-api03-..."
IP_HASH_SALT="any-long-random-string"

# Public vars (already set in wrangler.toml [vars] for production; override here for local dev)
VITE_AUTH0_DOMAIN="your-tenant.us.auth0.com"
VITE_AUTH0_CLIENT_ID="your-auth0-client-id"

# Optional: used to build chart share URLs. Falls back to request origin if unset.
SITE_URL="http://localhost:8787"
