# Build-time environment variables for production Vite builds.
# These are public Auth0 SPA credentials — inlined into the frontend bundle
# by Vite via `import.meta.env.VITE_*`. Safe to commit.
# See CLAUDE.md → Environment Variables for the full picture.

VITE_AUTH0_DOMAIN=dev-zy7obc7gqpztqadk.us.auth0.com
VITE_AUTH0_CLIENT_ID=eGHWLKnz44EPGWfmCdcVvYY5SBSMX01B

# Cloudflare Turnstile (anonymous bot defense). Public site key — the widget
# reads it at build time; the Worker verifies tokens via TURNSTILE_SECRET_KEY
# (stored as a Worker secret via `wrangler secret put`).
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADA7hqLrQ0ppcrNW
