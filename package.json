{
  "name": "theory-of-change-builder",
  "private": true,
  "version": "0.1.0",
  "description": "Interactive web app for creating Theory of Change diagrams with AI assistance",
  "repository": {
    "type": "git",
    "url": "https://github.com/ToC-Maker/theory-of-change-builder"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build && wrangler dev",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "pretest": "mkdir -p dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preflight": "run-p --print-label --aggregate-output typecheck lint format:check build test",
    "preflight:serial": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.2",
    "@heroicons/react": "^2.2.0",
    "@mdxeditor/editor": "3.54.1",
    "@neondatabase/serverless": "^1.1.0",
    "clsx": "^2.1.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.14.1",
    "react-tooltip": "^5.30.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@cloudflare/vitest-pool-workers": "0.14.7",
    "@cloudflare/workers-types": "4.20260417.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/test": "^8.6.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.19.17",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.5.0",
    "jose": "^6.2.2",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "8.0.4",
    "postcss": "^8.5.10",
    "prettier": "3.8.3",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "wrangler": "4.83.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run preflight"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,jsonc,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/expect": "4.1.4",
    "@vitest/spy": "4.1.4",
    "@vitest/utils": "4.1.4"
  }
}
